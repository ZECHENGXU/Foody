SECRET_KEY=replace-this-secret
DATABASE_URL=sqlite:///./foody.db
CORS_ORIGINS=http://localhost:5173
DEMO_USER_EMAIL=demo@example.com
DEMO_USER_PASSWORD=demo123456

# AI provider: auto | mock | openai | anthropic | gemini | openai_compatible
AI_PROVIDER=auto
AI_FALLBACK_TO_MOCK=true
AI_TIMEOUT_SECONDS=60

# Native OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Native Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# Native Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Generic OpenAI-compatible providers
# This covers many mainstream providers that expose /chat/completions:
# OpenRouter, Groq, Together, Fireworks, DeepSeek, Moonshot, SiliconFlow, DashScope-compatible endpoints, etc.
COMPATIBLE_PROVIDER_NAME=openai-compatible
COMPATIBLE_API_KEY=
COMPATIBLE_MODEL=
COMPATIBLE_BASE_URL=
COMPATIBLE_API_KEY_HEADER=Authorization
COMPATIBLE_API_KEY_PREFIX=Bearer
COMPATIBLE_EXTRA_HEADERS_JSON={}
COMPATIBLE_EXTRA_BODY_JSON={}
