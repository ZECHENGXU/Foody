{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: setup venv",
      "type": "shell",
      "command": "if (!(Test-Path '.venv')) { python -m venv .venv }",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: install deps",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "dependsOn": "backend: setup venv",
      "problemMatcher": []
    },
    {
      "label": "backend: ensure env",
      "type": "shell",
      "command": "if (!(Test-Path '.env')) { Copy-Item '.env.example' '.env' }",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "backend: run",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m uvicorn app.main:app --reload --port 8000",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "dependsOn": [
        "backend: ensure env",
        "backend: install deps"
      ],
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Uvicorn running on.*|.*Started reloader process.*",
          "endsPattern": ".*Uvicorn running on.*"
        }
      }
    },
    {
      "label": "frontend: install deps",
      "type": "shell",
      "command": "npm.cmd install",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "frontend: run",
      "type": "shell",
      "command": "npm.cmd run dev -- --host 0.0.0.0 --port 5173",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "dependsOn": "frontend: install deps",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*VITE.*",
          "endsPattern": ".*Local:.*5173.*|.*ready in.*"
        }
      }
    },
    {
      "label": "app: run all",
      "dependsOrder": "parallel",
      "dependsOn": [
        "backend: run",
        "frontend: run"
      ],
      "problemMatcher": []
    }
  ]
}

